{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "watchPatterns": [
      "scripts/**",
      "app/backtesting/**",
      "app/models/**",
      "app/database/**",
      "app/config.py",
      "model_artifacts/**",
      "requirements.txt",
      "Dockerfile",
      "railway.cron.json"
    ]
  },
  "deploy": {
    "startCommand": "python3 scripts/refresh_and_evaluate.py --storage database",
    "restartPolicyType": "NEVER"
  }
}
